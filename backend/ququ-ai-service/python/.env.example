# =============================================================================
# Ququ AI Service — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to Git (it's already in .gitignore).
# =============================================================================

# --- General ---
# Provider: 'openai' | 'deepseek' | 'qwen' | 'wenxin' | 'mock'
AI_PROVIDER=mock
# Mode: 'mock' (no API calls, keyword rules) or 'live' (real LLM)
AI_MODE=mock
# Model name (leave empty to use provider default)
#   deepseek: deepseek-chat / deepseek-reasoner
#   qwen:     qwen-plus / qwen-max / qwen-turbo
#   openai:   gpt-4o / gpt-4-turbo
# AI_MODEL=

# --- DeepSeek (文本 LLM) ---
# Base URL defaults to https://api.deepseek.com
# DEEPSEEK_BASE_URL=
DEEPSEEK_API_KEY=sk-your-deepseek-key

# --- 通义千问 / Qwen (文本 LLM，DashScope OpenAI-compatible) ---
# Base URL defaults to https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_BASE_URL=
QWEN_API_KEY=sk-your-qwen-key

# --- OpenAI (备用) ---
# OPENAI_BASE_URL=
OPENAI_API_KEY=sk-your-openai-key

# --- 百度文心一言 (native SDK, 非 OpenAI-compatible) ---
WENXIN_API_KEY=your-wenxin-api-key
WENXIN_SECRET_KEY=your-wenxin-secret-key

# --- Vision Model (图片分类) ---
# 可选: 'openai' (GPT-4V) | 'qwen' (qwen-vl-plus/qwen-vl-max) | 留空跟随 AI_PROVIDER
# 注意: DeepSeek 没有视觉模型，如果 AI_PROVIDER=deepseek，请设置 VISION_PROVIDER=qwen
# VISION_PROVIDER=
# VISION_MODEL=

# --- Timeouts & Retries (seconds) ---
LLM_TIMEOUT=30
LLM_RETRY_TIMES=1
VISION_TIMEOUT=20

# --- Redis (审核结果缓存，可选) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REVIEW_CACHE_TTL=86400

# --- Review Decision Thresholds ---
REVIEW_AUTO_PASS_CONFIDENCE=0.7
REVIEW_AUTO_REJECT_CONFIDENCE=0.9
REVIEW_AUTO_PASS_MAX_PARTICIPANTS=50

# --- Logging ---
LOG_LEVEL=INFO
