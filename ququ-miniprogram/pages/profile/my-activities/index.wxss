.title {
  margin-bottom: 22rpx;
  font-size: 42rpx;
  font-weight: 800;
}

.tabs {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-bottom: 22rpx;
}

.tab {
  min-height: 64rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #eef2f6;
  color: #626d7c;
  text-align: center;
  line-height: 64rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.tab.active {
  background: #1f7a5a;
  color: #ffffff;
}

.state {
  padding: 26rpx;
  color: #77808f;
  font-size: 26rpx;
  line-height: 1.6;
}

.state.error {
  color: #b5473f;
  background: #fff6f4;
  border-color: #f1c2bc;
}

.activity {
  margin-top: 18rpx;
  padding: 24rpx;
}

.activity-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.activity-title {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 800;
}

.status {
  flex: 0 0 auto;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #edf7f2;
  color: #1f7a5a;
  font-size: 22rpx;
  font-weight: 700;
}

.meta {
  margin-top: 12rpx;
  color: #77808f;
  font-size: 24rpx;
  line-height: 1.45;
}

.tags {
  margin-top: 16rpx;
}
