.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 -4rpx;
  padding: 0 24rpx;
}

.title {
  margin-bottom: 10rpx;
  font-size: 42rpx;
  font-weight: 800;
}

.create-btn,
.join {
  width: 148rpx;
  height: 62rpx;
  border-radius: 999rpx;
  background: #1f7a5a;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  flex: 0 0 148rpx;
}

.create-btn {
  transform: translateX(20rpx);
}

.state {
  margin-top: 28rpx;
  padding: 26rpx;
  color: #77808f;
  font-size: 26rpx;
  line-height: 1.6;
}

.state.error {
  color: #b5473f;
  background: #fff6f4;
  border-color: #f1c2bc;
}

.team {
  margin-top: 20rpx;
  padding: 24rpx;
}

.team-head,
.team-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.team-main {
  flex: 1;
  min-width: 0;
}

.team-name {
  min-height: 44rpx;
  font-size: 31rpx;
  line-height: 1.35;
  font-weight: 800;
}

.topic {
  margin: 12rpx 0 18rpx;
  line-height: 1.5;
}

.team-tags {
  min-height: 56rpx;
  flex: 1;
  min-width: 0;
}

.join {
  width: 104rpx;
  height: 56rpx;
  flex: 0 0 104rpx;
  background: #edf7f2;
  color: #1f7a5a;
  font-size: 24rpx;
}

.join.joined {
  color: #77808f;
  background: #f1f3f6;
}

.member-count {
  flex: 0 0 96rpx;
  color: #77808f;
  font-size: 27rpx;
  text-align: right;
  white-space: nowrap;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx;
  background: rgba(0, 0, 0, 0.45);
}

.modal {
  width: 100%;
  max-height: 86vh;
  padding: 30rpx;
  overflow-y: auto;
}

.modal-title {
  margin-bottom: 24rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 800;
}

.compact-textarea {
  min-height: 128rpx;
}

.picker-box {
  width: 100%;
  min-height: 76rpx;
  padding: 0 22rpx;
  border: 1rpx solid #dde3eb;
  border-radius: 12rpx;
  background: #ffffff;
  color: #19202b;
  line-height: 76rpx;
}

.modal-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 12rpx;
}

.modal-actions .btn {
  width: 100%;
}
