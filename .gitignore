# =============================================================================
# 趣聚平台 (OnlyFriends) Monorepo .gitignore
# 技术栈：Spring Boot · FastAPI · 微信小程序 · Vue 3 · Docker
# =============================================================================

# -----------------------------------------------------------------------------
# 操作系统
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# IDE / 编辑器
# -----------------------------------------------------------------------------
# IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws
out/

# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example

# Eclipse
.classpath
.project
.settings/
bin/

# NetBeans
nbproject/
build/
nbbuild/
dist/
nbdist/
.nb-gradle/

# Cursor
.cursor/

# -----------------------------------------------------------------------------
# Java / Maven / Spring Boot
# -----------------------------------------------------------------------------
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*

# Spring Boot
spring-boot-devtools.properties

# 本地配置文件（含数据库密码、JWT Secret 等，勿提交）
**/src/main/resources/application-local.yml
**/src/main/resources/application-local.yaml
**/src/main/resources/application-dev.yml
**/src/main/resources/application-dev.yaml
**/src/main/resources/application-prod.yml
**/src/main/resources/application-prod.yaml

# -----------------------------------------------------------------------------
# Python / FastAPI (ququ-ai-service)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
.env
.env.*
!.env.example
!.env.template
pip-log.txt
pip-delete-this-directory.txt
*.egg
*.egg-info/
.eggs/
dist/
build/
*.manifest
*.spec
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/
.pytype/
cython_debug/
*.cover
.hypothesis/
instance/
.webassets-cache
celerybeat-schedule
celerybeat.pid
*.log

# uv / poetry
.uv/
poetry.lock

# Jupyter
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# Node.js / Vue 3 (ququ-admin-web)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/

# Vite / Vue 构建产物
dist/
dist-ssr/
*.local

# 环境变量
.env
.env.*
!.env.example
!.env.development.example
!.env.production.example

# 测试覆盖率
coverage/
*.lcov
.nyc_output/

# TypeScript
*.tsbuildinfo

# ESLint / Prettier 缓存
.eslintcache
.prettiercache

# -----------------------------------------------------------------------------
# 微信小程序 (ququ-miniprogram)
# -----------------------------------------------------------------------------
miniprogram_npm/
**/miniprogram_npm/

# 微信开发者工具私有配置（含 AppID 等）
project.private.config.json

# 小程序构建产物
**/dist/
**/build/

# -----------------------------------------------------------------------------
# Docker / 基础设施本地数据
# -----------------------------------------------------------------------------
# docker-compose 挂载的持久化数据（MySQL / Redis / MinIO）
data/
!data/.gitkeep

# Docker 覆盖配置（含本地密码）
docker-compose.override.yml
docker-compose.local.yml

# -----------------------------------------------------------------------------
# 密钥与敏感信息
# -----------------------------------------------------------------------------
*.pem
*.key
*.p12
*.jks
*.keystore
secrets/
credentials/
*.credentials
*.secret

# Nacos 本地配置导出
nacos/data/
nacos/logs/

# MinIO 本地数据
minio-data/

# -----------------------------------------------------------------------------
# 日志与临时文件
# -----------------------------------------------------------------------------
logs/
*.log
*.log.*
log/
tmp/
temp/
*.tmp
*.temp
*.swp
*.swo
*~
.cache/

# -----------------------------------------------------------------------------
# 测试与覆盖率报告
# -----------------------------------------------------------------------------
test-results/
test-output/
surefire-reports/
failsafe-reports/
jacoco.exec
*.exec

# -----------------------------------------------------------------------------
# 打包与部署产物
# -----------------------------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.rar
*.7z
release/
deploy/

# -----------------------------------------------------------------------------
# 其他
# -----------------------------------------------------------------------------
*.bak
*.orig
*.rej
.sass-cache/
.parcel-cache/
.turbo/
.vercel/
.netlify/
