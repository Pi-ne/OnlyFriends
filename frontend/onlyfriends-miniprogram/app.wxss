page {
  min-height: 100%;
  background: #f7f8fb;
  color: #1a1f28;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input,
textarea,
picker {
  box-sizing: border-box;
}

button {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  border-radius: 0;
  line-height: normal;
  font-weight: 600;
}

button::after {
  border: 0;
}

button[disabled] {
  opacity: 0.45;
}

/* ── Layout ── */
.page {
  min-height: 100vh;
  padding: 28rpx;
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
}

.section {
  margin-top: 28rpx;
}

.page-header {
  margin-bottom: 28rpx;
}

.page-title {
  font-size: 40rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #1a1f28;
  letter-spacing: -0.5rpx;
}

.page-subtitle {
  margin-top: 10rpx;
  color: #8b939e;
  font-size: 26rpx;
  line-height: 1.5;
}

/* ── Card ── */
.card {
  background: #ffffff;
  border: 1rpx solid #eef0f3;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(18, 38, 63, 0.05);
}

.muted {
  color: #8b939e;
}

.row {
  display: flex;
  align-items: center;
}

.between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* ── Buttons ── */
.btn {
  height: 88rpx;
  padding: 0 32rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #1a6b4f 0%, #2b8a67 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(31, 122, 90, 0.22);
}

.btn:active {
  opacity: 0.88;
}

.btn[disabled] {
  box-shadow: none;
}

.btn.secondary {
  background: #edf7f2;
  color: #1f7a5a;
  box-shadow: none;
}

.btn.ghost {
  background: #ffffff;
  color: #1f7a5a;
  border: 1rpx solid #c8ddd4;
  box-shadow: none;
}

.btn.muted {
  background: #f5f7fa;
  color: #8b939e;
  border: 0;
  box-shadow: none;
}

.btn.wechat {
  background: linear-gradient(135deg, #06ae56 0%, #07c160 100%);
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.25);
}

.btn.small {
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
}

.btn.compact {
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
}

.btn.pill {
  border-radius: 999rpx;
}

.btn.block {
  width: 100%;
}

.btn-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 64rpx;
  width: 64rpx;
  height: 64rpx;
  padding: 0;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #1a6b4f 0%, #2b8a67 100%);
  box-shadow: 0 6rpx 16rpx rgba(31, 122, 90, 0.2);
}

.btn-float {
  height: 64rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.96);
  color: #1f7a5a;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid rgba(31, 122, 90, 0.12);
  box-shadow: 0 10rpx 28rpx rgba(25, 32, 43, 0.12);
}

.btn-group {
  display: flex;
  gap: 16rpx;
}

.btn-group.split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.btn-group.split .btn {
  width: 100%;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  display: flex;
  gap: 16rpx;
  padding: 16rpx 28rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid #eef0f3;
  backdrop-filter: blur(12rpx);
}

.bottom-bar .btn.share {
  flex: 0 0 168rpx;
  width: 168rpx;
}

.bottom-bar .btn:not(.share) {
  flex: 1;
}

/* ── Tabs: underline ── */
.tabs-line {
  display: flex;
  gap: 40rpx;
  border-bottom: 1rpx solid #eef0f3;
}

.tab-line {
  position: relative;
  padding: 16rpx 0 20rpx;
  color: #a8b0bc;
  font-size: 28rpx;
  font-weight: 500;
}

.tab-line.active {
  color: #1a1f28;
  font-weight: 600;
}

.tab-indicator {
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: linear-gradient(90deg, #1f7a5a, #68b684);
}

/* ── Tabs: segmented ── */
.tabs-segment {
  display: flex;
  gap: 8rpx;
  padding: 8rpx;
  border-radius: 20rpx;
  background: #eef0f3;
}

.tab-segment {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  border-radius: 14rpx;
  color: #8b939e;
  text-align: center;
  line-height: 64rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.tab-segment.active {
  background: #ffffff;
  color: #1f7a5a;
  box-shadow: 0 4rpx 12rpx rgba(18, 38, 63, 0.08);
}

/* ── Tags ── */
.tag {
  display: inline-flex;
  align-items: center;
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(31, 122, 90, 0.08);
  color: #1f7a5a;
  font-size: 22rpx;
  font-weight: 500;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.tag.gray {
  background: #f5f7fa;
  color: #626d7c;
}

.tag.warn {
  background: rgba(242, 193, 78, 0.15);
  color: #a35f18;
}

/* ── Status badge ── */
.status-badge {
  flex: 0 0 auto;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(31, 122, 90, 0.1);
  color: #1f7a5a;
  font-size: 22rpx;
  font-weight: 600;
}

.status-badge.warn {
  background: rgba(242, 193, 78, 0.15);
  color: #a35f18;
}

.status-badge.gray {
  background: #f5f7fa;
  color: #8b939e;
}

/* ── Filter chips ── */
.filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.filter-chip {
  height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #f5f7fa;
  color: #626d7c;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 56rpx;
}

.filter-chip.active {
  background: linear-gradient(135deg, #1a6b4f 0%, #2b8a67 100%);
  color: #ffffff;
}

/* ── Form ── */
.input {
  width: 100%;
  min-height: 80rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e4e8ee;
  border-radius: 16rpx;
  background: #ffffff;
  color: #1a1f28;
  font-size: 28rpx;
}

.textarea {
  width: 100%;
  min-height: 168rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid #e4e8ee;
  border-radius: 16rpx;
  background: #ffffff;
  color: #1a1f28;
  font-size: 28rpx;
}

.field {
  margin-bottom: 24rpx;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  color: #3a4350;
  font-size: 26rpx;
  font-weight: 600;
}

/* ── States ── */
.state {
  padding: 32rpx;
  color: #8b939e;
  font-size: 26rpx;
  line-height: 1.6;
  text-align: center;
}

.state.error {
  color: #c45c4a;
  background: #fff6f4;
  border-color: #f5d5cf;
}

.state-title {
  display: block;
  color: #626d7c;
  font-size: 30rpx;
  font-weight: 600;
}

.state-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
}

.state-actions {
  margin-top: 24rpx;
}

.section-title {
  margin-bottom: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1f28;
}

.section-title.compact {
  margin-bottom: 8rpx;
}
