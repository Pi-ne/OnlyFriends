.page-title {
  margin-bottom: 22rpx;
}

.tabs-segment {
  margin-bottom: 22rpx;
}

.activity {
  margin-top: 18rpx;
  padding: 24rpx;
}

.activity-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.activity-title {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
}

.meta {
  margin-top: 12rpx;
  color: #8b939e;
  font-size: 24rpx;
  line-height: 1.45;
}

.tags {
  margin-top: 16rpx;
}
