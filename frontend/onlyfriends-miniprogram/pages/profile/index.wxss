.profile {
  padding-top: 12rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* ── Hero（与首页一致） ── */
.profile-hero {
  position: relative;
  padding: 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #164734 0%, #1f7a5a 52%, #68b684 100%);
  overflow: hidden;
  box-shadow: 0 16rpx 40rpx rgba(22, 71, 52, 0.22);
}

.hero-glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.hero-glow-a {
  top: -60rpx;
  right: -40rpx;
  width: 220rpx;
  height: 220rpx;
  background: radial-gradient(circle, rgba(242, 193, 78, 0.45) 0%, transparent 70%);
}

.hero-glow-b {
  bottom: -80rpx;
  left: -30rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.18) 0%, transparent 70%);
}

.hero-row {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-icon {
  width: 48rpx;
  height: 48rpx;
  filter: brightness(0) invert(1);
  opacity: 0.92;
}

.hero-content {
  flex: 1;
  min-width: 0;
}

.eyebrow {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.82);
  font-weight: 600;
  letter-spacing: 2rpx;
}

.hero-name {
  margin-top: 8rpx;
  font-size: 36rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -0.5rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.45;
  color: rgba(255, 255, 255, 0.75);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-tags {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
}

.hero-tag {
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
  font-weight: 500;
}


/* ── Stats ── */
.stats-card {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  padding: 24rpx 12rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #1a1f28;
}

.stat-num.accent {
  color: #1f7a5a;
}

.stat-label {
  margin-top: 6rpx;
  color: #8b939e;
  font-size: 22rpx;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: #eef0f3;
  flex-shrink: 0;
}

/* ── Menu ── */
.menu-card {
  margin-top: 24rpx;
  padding: 4rpx 0;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  border-bottom: 1rpx solid #f3f5f8;
}

.menu-item:active {
  opacity: 0.7;
}

.menu-item.last {
  border-bottom: 0;
}

.menu-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1f28;
}

.menu-arrow {
  color: #c8cdd4;
  font-size: 32rpx;
  font-weight: 300;
}

/* ── Footer ── */
.footer-action {
  margin-top: 28rpx;
}
