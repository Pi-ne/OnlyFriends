<view class="page">
  <view class="title">我的报名</view>

  <view wx:if="{{loading}}" class="state card">正在加载报名活动...</view>
  <view wx:elif="{{error}}" class="state error card">{{error}}</view>
  <view wx:elif="{{activities.length === 0}}" class="state card">暂无报名活动。</view>

  <view wx:for="{{activities}}" wx:key="id" class="activity card" data-id="{{item.id}}" bindtap="goDetail">
    <view class="activity-head">
      <view class="activity-title">{{item.title}}</view>
      <view class="status">{{item.statusText}}</view>
    </view>
    <view class="meta">{{item.time}} · {{item.location}}</view>
    <view class="meta">{{item.feeText}} · {{item.joined}}/{{item.capacity}} 人</view>
    <view class="tags">
      <text wx:for="{{item.tags}}" wx:key="*this" class="tag">{{item}}</text>
    </view>
  </view>
</view>
