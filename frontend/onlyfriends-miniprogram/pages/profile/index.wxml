<view class="page profile">
  <view wx:if="{{loading}}" class="state card">正在加载资料...</view>

  <view class="hero profile-hero">
    <view class="hero-glow hero-glow-a"></view>
    <view class="hero-glow hero-glow-b"></view>
    <view class="hero-row">
      <view class="avatar">
        <image class="avatar-icon" src="/assets/tabbar/profile.png" mode="aspectFit" />
      </view>
      <view class="hero-content">
        <view class="eyebrow">{{user.role}}</view>
        <view class="hero-name">{{user.nickname}}</view>
        <view class="hero-meta">{{user.city}}</view>
      </view>
    </view>
    <view wx:if="{{user.tags.length}}" class="hero-tags">
      <text wx:for="{{user.tags}}" wx:key="*this" class="hero-tag">{{item}}</text>
    </view>
  </view>

  <view class="stats-card card">
    <view class="stat-item">
      <view class="stat-num">{{statsLoading ? "…" : stats.registeredCount}}</view>
      <view class="stat-label">已报名</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-num">{{statsLoading ? "…" : stats.createdCount}}</view>
      <view class="stat-label">发起活动</view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <view class="stat-num accent">{{loggedIn ? user.creditScore : "—"}}</view>
      <view class="stat-label">信誉分</view>
    </view>
  </view>

  <view class="menu-card card">
    <view class="menu-item" bindtap="goRegistrations">
      <text class="menu-text">我的报名</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goMyActivities">
      <text class="menu-text">我创建的活动</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goFriends">
      <text class="menu-text">关注与好友</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item last" bindtap="applyMerchant">
      <text class="menu-text">商家身份申请</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="footer-action">
    <button wx:if="{{!loggedIn}}" class="btn block" bindtap="goLogin">登录 / 注册</button>
    <button wx:else class="btn ghost block" bindtap="logout">退出登录</button>
  </view>
</view>
