.follows-page {
  padding-top: 12rpx;
}

.tabs-segment {
  margin-bottom: 24rpx;
}

.follow-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.follow-user {
  padding: 24rpx;
}

.follow-profile {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-width: 0;
}

.follow-avatar {
  flex: 0 0 auto;
  width: 82rpx;
  height: 82rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #1a1f28, #3a4350);
  color: #ffffff;
  text-align: center;
  line-height: 82rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.follow-info {
  flex: 1;
  min-width: 0;
}

.follow-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #1a1f28;
}

.follow-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
  color: #8b939e;
  font-size: 24rpx;
  line-height: 1.35;
}

.follow-badge {
  display: inline-flex;
  align-items: center;
  height: 38rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: rgba(31, 122, 90, 0.1);
  color: #1f7a5a;
  font-size: 21rpx;
  font-weight: 600;
}

.follow-actions {
  margin-top: 22rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eef0f3;
}

.follow-actions .btn {
  flex: 1;
  min-width: 0;
}
