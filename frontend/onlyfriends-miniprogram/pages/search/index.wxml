<view class="page">
  <view class="search-panel card">
    <input class="input" value="{{keyword}}" placeholder="输入活动名称、简介或地点" bindinput="onInput" />
    <view class="filter-row">
      <view wx:for="{{filters}}" wx:key="*this" data-filter="{{item}}" bindtap="pickFilter" class="filter {{activeFilter === item ? 'active' : ''}}">{{item}}</view>
    </view>
    <view class="between">
      <view class="muted">{{results.length}} 个结果</view>
      <button class="clear" bindtap="clearFilters">清空</button>
    </view>
  </view>

  <view wx:if="{{loading}}" class="empty card">
    <view class="empty-title">正在搜索活动...</view>
  </view>

  <view wx:elif="{{error}}" class="empty card">
    <view class="empty-title">{{error}}</view>
  </view>

  <view wx:elif="{{results.length === 0}}" class="empty card">
    <view class="empty-title">没有找到匹配活动</view>
    <view class="muted">换个关键词或清空筛选试试。</view>
  </view>

  <view wx:for="{{results}}" wx:key="id" class="result-card card" data-id="{{item.id}}" bindtap="goDetail">
    <view class="between">
      <view class="result-title">{{item.title}}</view>
      <view class="status">{{item.status}}</view>
    </view>
    <view class="muted line">{{item.time}} · {{item.location}}</view>
    <view class="muted line">{{item.category}} · {{item.distance}} · {{item.fee}}</view>
  </view>
</view>
