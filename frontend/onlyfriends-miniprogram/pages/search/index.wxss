.search-panel {
  padding: 24rpx;
}

.search-panel .filter-row {
  margin: 22rpx 0;
}

.result-card,
.empty {
  margin-top: 20rpx;
  padding: 24rpx;
}

.result-title {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
}

.line {
  margin-top: 12rpx;
}

.empty {
  text-align: center;
}

.empty-title {
  margin-bottom: 12rpx;
  font-size: 30rpx;
  font-weight: 700;
}
