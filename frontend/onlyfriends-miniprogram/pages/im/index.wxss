.page-title {
  margin-bottom: 24rpx;
}

.conversation {
  position: relative;
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 18rpx;
  padding: 22rpx;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #1a6b4f, #2b8a67);
  color: #ffffff;
  text-align: center;
  line-height: 88rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.conv-main {
  flex: 1;
  min-width: 0;
}

.conv-name {
  max-width: 420rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 29rpx;
  font-weight: 700;
}

.time {
  font-size: 22rpx;
}

.last {
  margin-top: 10rpx;
  color: #8b939e;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.badge {
  position: absolute;
  right: 20rpx;
  bottom: 18rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #d94c3d;
  color: #ffffff;
  text-align: center;
  line-height: 34rpx;
  font-size: 22rpx;
}
