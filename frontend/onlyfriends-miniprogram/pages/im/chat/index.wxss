.chat-page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(128rpx + env(safe-area-inset-bottom));
  background: #f7f8fb;
}

.chat-state {
  margin-bottom: 18rpx;
  padding: 24rpx;
}

.message-list {
  height: calc(100vh - 156rpx);
}

.message-row {
  display: flex;
  justify-content: flex-start;
  margin-bottom: 20rpx;
}

.message-row.mine {
  justify-content: flex-end;
}

.message-bubble {
  max-width: 560rpx;
  padding: 18rpx 20rpx 14rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 1rpx solid #eef0f3;
  box-shadow: 0 8rpx 20rpx rgba(18, 38, 63, 0.05);
}

.message-row.mine .message-bubble {
  background: linear-gradient(135deg, #1a6b4f, #2b8a67);
  color: #ffffff;
  border-color: transparent;
}

.message-bubble.recalled {
  background: #eef0f3;
  color: #8b939e;
  border-color: #eef0f3;
}

.message-content {
  font-size: 28rpx;
  line-height: 1.55;
  word-break: break-all;
}

.message-time {
  margin-top: 8rpx;
  color: #9aa3b2;
  font-size: 20rpx;
  text-align: right;
}

.message-row.mine .message-time {
  color: rgba(255, 255, 255, 0.72);
}

.composer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid #eef0f3;
  backdrop-filter: blur(12rpx);
}

.composer-input {
  flex: 1;
  min-width: 0;
  height: 80rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e4e8ee;
  background: #ffffff;
}

.composer .btn {
  flex: 0 0 128rpx;
  width: 128rpx;
  height: 80rpx;
  border-radius: 16rpx;
  box-shadow: none;
}
