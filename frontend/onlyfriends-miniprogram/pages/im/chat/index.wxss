.chat-page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(128rpx + env(safe-area-inset-bottom));
  background: #f7f8fb;
}

.chat-page.group-chat {
  padding-top: 12rpx;
}

.group-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
  padding: 20rpx 24rpx;
}

.group-toolbar-main {
  min-width: 0;
}

.group-toolbar-title {
  font-size: 28rpx;
  font-weight: 700;
}

.group-toolbar-desc {
  margin-top: 6rpx;
  color: #8b939e;
  font-size: 22rpx;
}

.group-toolbar-action {
  flex: 0 0 auto;
  color: #1a6b4f;
  font-size: 24rpx;
  font-weight: 600;
}

.chat-page.group-chat .message-list {
  height: calc(100vh - 248rpx);
}

.chat-state {
  margin-bottom: 18rpx;
  padding: 24rpx;
}

.message-list {
  height: calc(100vh - 156rpx);
}

.message-row {
  display: flex;
  justify-content: flex-start;
  margin-bottom: 20rpx;
}

.message-row.mine {
  justify-content: flex-end;
}

.message-bubble {
  max-width: 560rpx;
  padding: 18rpx 20rpx 14rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 1rpx solid #eef0f3;
  box-shadow: 0 8rpx 20rpx rgba(18, 38, 63, 0.05);
}

.message-row.mine .message-bubble {
  background: linear-gradient(135deg, #1a6b4f, #2b8a67);
  color: #ffffff;
  border-color: transparent;
}

.message-bubble.recalled {
  background: #eef0f3;
  color: #8b939e;
  border-color: #eef0f3;
}

.message-sender {
  margin-bottom: 6rpx;
  color: #1a6b4f;
  font-size: 22rpx;
  font-weight: 600;
}

.message-row.mine .message-sender {
  color: rgba(255, 255, 255, 0.88);
}

.message-content {
  font-size: 28rpx;
  line-height: 1.55;
  word-break: break-all;
}

.message-time {
  margin-top: 8rpx;
  color: #9aa3b2;
  font-size: 20rpx;
  text-align: right;
}

.message-row.mine .message-time {
  color: rgba(255, 255, 255, 0.72);
}

.composer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid #eef0f3;
  backdrop-filter: blur(12rpx);
}

.composer-input {
  flex: 1;
  min-width: 0;
  height: 80rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e4e8ee;
  background: #ffffff;
}

.composer .btn {
  flex: 0 0 128rpx;
  width: 128rpx;
  height: 80rpx;
  border-radius: 16rpx;
  box-shadow: none;
}

.members-mask {
  position: fixed;
  inset: 0;
  z-index: 100;
  background: rgba(18, 38, 63, 0.42);
  display: flex;
  align-items: flex-end;
}

.members-panel {
  width: 100%;
  max-height: 72vh;
  border-radius: 28rpx 28rpx 0 0;
  padding: 28rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
}

.members-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.members-title {
  font-size: 32rpx;
  font-weight: 700;
}

.members-subtitle {
  margin-top: 6rpx;
  color: #8b939e;
  font-size: 22rpx;
}

.members-close {
  color: #1a6b4f;
  font-size: 26rpx;
  font-weight: 600;
}

.members-state {
  padding: 40rpx 0;
  text-align: center;
  color: #8b939e;
  font-size: 26rpx;
}

.members-state.error {
  color: #d94c3d;
}

.members-list {
  max-height: 56vh;
}

.member-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef0f3;
}

.member-row:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #1a6b4f, #2b8a67);
  color: #ffffff;
  text-align: center;
  line-height: 72rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.member-main {
  flex: 1;
  min-width: 0;
}

.member-name {
  font-size: 28rpx;
  font-weight: 600;
}

.member-meta {
  margin-top: 6rpx;
  color: #9aa3b2;
  font-size: 22rpx;
}

.member-role {
  flex: 0 0 auto;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #eef0f3;
  color: #77808f;
  font-size: 22rpx;
}

.member-role.owner {
  background: rgba(26, 107, 79, 0.12);
  color: #1a6b4f;
  font-weight: 700;
}

.member-role.admin {
  background: rgba(47, 111, 237, 0.12);
  color: #2f6fed;
  font-weight: 600;
}

.members-footer {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eef0f3;
}

.members-footer .btn.danger {
  background: #fff5f4;
  color: #d94c3d;
  border: 1rpx solid rgba(217, 76, 61, 0.28);
  box-shadow: none;
}
