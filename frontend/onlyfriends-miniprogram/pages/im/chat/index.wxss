.chat-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 128rpx;
  background: #f7f8fb;
}

.chat-state {
  margin-bottom: 18rpx;
  padding: 24rpx;
  color: #77808f;
  font-size: 26rpx;
  line-height: 1.6;
}

.chat-error {
  color: #b5473f;
  background: #fff6f4;
  border-color: #f1c2bc;
}

.message-list {
  height: calc(100vh - 156rpx);
}

.message-row {
  display: flex;
  justify-content: flex-start;
  margin-bottom: 20rpx;
}

.message-row.mine {
  justify-content: flex-end;
}

.message-bubble {
  max-width: 560rpx;
  padding: 18rpx 20rpx 14rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e8ecf2;
  box-shadow: 0 8rpx 20rpx rgba(18, 38, 63, 0.05);
}

.message-row.mine .message-bubble {
  background: #1f7a5a;
  color: #ffffff;
  border-color: #1f7a5a;
}

.message-bubble.recalled {
  background: #eef2f6;
  color: #77808f;
  border-color: #e8ecf2;
}

.message-content {
  font-size: 28rpx;
  line-height: 1.55;
  word-break: break-all;
}

.message-time {
  margin-top: 8rpx;
  color: #9aa3b2;
  font-size: 20rpx;
  text-align: right;
}

.message-row.mine .message-time {
  color: rgba(255, 255, 255, 0.72);
}

.composer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 18rpx 24rpx 40rpx;
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid #e8ecf2;
}

.composer-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 22rpx;
  border-radius: 14rpx;
  border: 1rpx solid #dde3eb;
  background: #ffffff;
}

.send-btn {
  flex: 0 0 auto;
  width: 128rpx;
  height: 76rpx;
  border-radius: 14rpx;
  background: #1f7a5a;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
}
