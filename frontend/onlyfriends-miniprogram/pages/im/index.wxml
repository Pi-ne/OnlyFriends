<view class="page">
  <view class="page-title">消息</view>

  <view wx:if="{{loading}}" class="state card">正在加载会话...</view>
  <view wx:elif="{{!loggedIn}}" class="state card">
    <view>登录后查看私聊和群聊。</view>
    <view class="state-actions">
      <button class="btn block" bindtap="goLogin">去登录</button>
    </view>
  </view>
  <view wx:elif="{{error}}" class="state error card">{{error}}</view>
  <view wx:elif="{{conversations.length === 0}}" class="state card">暂无会话。加入小队或成为好友后即可开始聊天。</view>

  <view wx:for="{{conversations}}" wx:key="id" data-id="{{item.id}}" bindtap="openConversation" class="conversation card">
    <view class="avatar">{{item.avatarText}}</view>
    <view class="conv-main">
      <view class="between">
        <view class="conv-name">{{item.title}}</view>
        <view class="muted time">{{item.time}}</view>
      </view>
      <view class="last">{{item.last}}</view>
    </view>
    <view wx:if="{{item.unread > 0}}" class="badge">{{item.unread}}</view>
  </view>
</view>
