.auth {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding-top: 0;
}

.auth-main {
  width: 100%;
  margin-top: -80rpx;
}

.auth-hero {
  position: relative;
  padding: 48rpx 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #164734 0%, #1f7a5a 52%, #68b684 100%);
  overflow: hidden;
  box-shadow: 0 16rpx 40rpx rgba(22, 71, 52, 0.22);
  text-align: center;
}

.hero-glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.hero-glow-a {
  top: -60rpx;
  right: -40rpx;
  width: 220rpx;
  height: 220rpx;
  background: radial-gradient(circle, rgba(242, 193, 78, 0.45) 0%, transparent 70%);
}

.hero-glow-b {
  bottom: -80rpx;
  left: -30rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.18) 0%, transparent 70%);
}

.eyebrow {
  position: relative;
  z-index: 1;
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.72);
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.auth-title {
  position: relative;
  z-index: 1;
  margin-top: 16rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1.35;
}

.auth-main .btn {
  margin-top: 48rpx;
}
