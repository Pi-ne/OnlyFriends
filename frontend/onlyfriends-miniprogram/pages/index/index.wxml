<view class="page home">
  <view class="search-box">
    <view class="search-main" bindtap="goSearch">
      <text class="search-icon">⌕</text>
      <text class="search-placeholder">搜索活动、地点或兴趣</text>
    </view>
    <button class="btn-icon" bindtap="goMap" aria-label="地图模式">
      <image class="map-icon" src="/assets/icons/map-arrow.png" mode="aspectFit" />
    </button>
  </view>

  <view class="hero">
    <view class="hero-glow hero-glow-a"></view>
    <view class="hero-glow hero-glow-b"></view>
    <view class="hero-content">
      <view class="eyebrow">Onlyfriends</view>
      <view class="title">今天想参加什么活动？</view>
    </view>
    <view class="hero-badge">北京</view>
  </view>

  <view class="tabs-line">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      data-key="{{item.key}}"
      bindtap="switchTab"
      class="tab-line {{activeTab === item.key ? 'active' : ''}}"
    >
      <text>{{item.label}}</text>
      <view wx:if="{{activeTab === item.key}}" class="tab-indicator"></view>
    </view>
  </view>

  <view class="activity-list">
    <view wx:if="{{loading}}" class="state">
      <view class="state-dot"></view>
      <text>正在加载活动...</text>
    </view>
    <view wx:elif="{{error}}" class="state state-error">{{error}}</view>
    <view wx:elif="{{currentList.length === 0}}" class="state state-empty">
      <text class="state-title">暂无活动</text>
      <text class="state-desc">发布一个活动后会显示在这里</text>
    </view>

    <view
      wx:for="{{currentList}}"
      wx:for-item="activity"
      wx:key="id"
      class="activity-card"
      data-id="{{activity.id}}"
      bindtap="goDetail"
    >
      <view class="card-cover {{activity.cover}}">
        <view class="cover-glow"></view>
        <view class="cover-top">
          <text class="category">{{activity.category}}</text>
          <text class="status-badge status-{{activity.statusClass}}">{{activity.status}}</text>
        </view>
      </view>
      <view class="card-body">
        <view class="card-title">{{activity.title}}</view>
        <view class="card-meta">
          <text>{{activity.time}}</text>
          <text class="meta-sep">·</text>
          <text class="meta-location">{{activity.location}}</text>
        </view>
        <view class="card-footer">
          <view class="chips">
            <text class="chip chip-{{activity.chipTone}}">{{activity.distance}}</text>
            <text class="chip chip-{{activity.chipTone}}">{{activity.fee}}</text>
          </view>
          <view class="seats">
            <text class="seats-num">{{activity.joined}}</text>
            <text class="seats-label">/ {{activity.capacity}} 人</text>
          </view>
        </view>
        <view wx:if="{{activity.displayTags.length}}" class="card-tags">
          <text wx:for="{{activity.displayTags}}" wx:key="*this" class="tag-minimal tag-{{activity.chipTone}}">{{item}}</text>
        </view>
      </view>
    </view>

    <view wx:if="{{showMapSuggestion}}" class="map-suggestion" bindtap="goMap">
      <view class="suggestion-text">
        <view class="suggestion-title">没有感兴趣的活动？</view>
        <view class="suggestion-sub">去地图里看看吧</view>
      </view>
      <view class="btn-icon suggestion-action">
        <image class="suggestion-icon" src="/assets/icons/map-arrow.png" mode="aspectFit" />
      </view>
    </view>
  </view>
</view>
