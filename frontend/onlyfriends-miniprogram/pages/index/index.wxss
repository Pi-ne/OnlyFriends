.home {
  padding-top: 12rpx;
}

/* ── Search ── */
.search-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 12rpx 0 28rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 1rpx solid #eef0f3;
  box-shadow: 0 8rpx 24rpx rgba(31, 122, 90, 0.06);
}

.search-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  height: 100%;
}

.search-icon {
  color: #1f7a5a;
  font-size: 32rpx;
  font-weight: 500;
  line-height: 1;
}

.search-placeholder {
  color: #a8b0bc;
  font-size: 28rpx;
  font-weight: 400;
}

.home .map-icon {
  width: 36rpx;
  height: 36rpx;
  filter: brightness(0) invert(1);
}

/* ── Hero ── */
.hero {
  position: relative;
  margin-top: 28rpx;
  padding: 36rpx 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #164734 0%, #1f7a5a 52%, #68b684 100%);
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  overflow: hidden;
  box-shadow: 0 16rpx 40rpx rgba(22, 71, 52, 0.22);
}

.hero-glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.hero-glow-a {
  top: -60rpx;
  right: -40rpx;
  width: 220rpx;
  height: 220rpx;
  background: radial-gradient(circle, rgba(242, 193, 78, 0.45) 0%, transparent 70%);
}

.hero-glow-b {
  bottom: -80rpx;
  left: -30rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.18) 0%, transparent 70%);
}

.hero-content {
  position: relative;
  z-index: 1;
  flex: 1;
}

.eyebrow {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.82);
  font-weight: 600;
  letter-spacing: 3rpx;
}

.title {
  margin-top: 16rpx;
  font-size: 40rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -0.5rpx;
}


.hero-badge {
  position: relative;
  z-index: 1;
  flex: 0 0 auto;
  margin-left: 20rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(8rpx);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 500;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
}

.home .tabs-line {
  margin-top: 36rpx;
}

/* ── Activity List ── */
.activity-list {
  margin-top: 28rpx;
}

.state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  color: #a8b0bc;
  font-size: 26rpx;
}

.state-dot {
  width: 12rpx;
  height: 12rpx;
  margin-bottom: 20rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1f7a5a, #68b684);
  animation: pulse 1.4s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.3; transform: scale(0.85); }
  50% { opacity: 1; transform: scale(1); }
}

.state-error {
  color: #c45c4a;
}

.state-empty {
  gap: 8rpx;
}

.state-title {
  color: #626d7c;
  font-size: 30rpx;
  font-weight: 600;
}

.state-desc {
  font-size: 24rpx;
}

/* ── Activity Card ── */
.activity-card {
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid #eef0f3;
  overflow: hidden;
  box-shadow: 0 10rpx 32rpx rgba(18, 38, 63, 0.07);
}

.activity-card:active {
  opacity: 0.92;
  transform: scale(0.995);
}

.card-cover {
  position: relative;
  height: 180rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: flex-start;
  overflow: hidden;
}

.cover-glow {
  position: absolute;
  top: -40rpx;
  right: -30rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.28) 0%, transparent 68%);
  pointer-events: none;
}

.cover-top {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

.category {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  backdrop-filter: blur(6rpx);
}

.status-badge {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  backdrop-filter: blur(6rpx);
}

.status-open {
  background: rgba(255, 255, 255, 0.92);
  color: #1f7a5a;
}

.status-live {
  background: rgba(255, 255, 255, 0.92);
  color: #315f9d;
}

.status-pending {
  background: rgba(255, 255, 255, 0.92);
  color: #c47a12;
}

.status-closed {
  background: rgba(255, 255, 255, 0.72);
  color: rgba(255, 255, 255, 0.95);
}

.status-default {
  background: rgba(255, 255, 255, 0.82);
  color: #626d7c;
}

/* Cover gradients */
.cover-soft-green {
  background: linear-gradient(135deg, #1a6b4f 0%, #2b8a67 55%, #7ec9a0 100%);
}

.cover-soft-green .category {
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.35);
}

.cover-soft-warm {
  background: linear-gradient(135deg, #a35f18 0%, #d4922a 50%, #f2c14e 100%);
}

.cover-soft-warm .category {
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.35);
}

.cover-soft-cool {
  background: linear-gradient(135deg, #254f8a 0%, #3d73b8 52%, #7eb6d9 100%);
}

.cover-soft-cool .category {
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.35);
}

.card-body {
  padding: 24rpx 28rpx 28rpx;
}

.card-title {
  font-size: 32rpx;
  line-height: 1.4;
  font-weight: 600;
  color: #1a1f28;
  letter-spacing: -0.3rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.card-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-top: 14rpx;
  color: #8b939e;
  font-size: 24rpx;
  line-height: 1.5;
}

.meta-sep {
  margin: 0 10rpx;
  color: #d0d5dc;
}

.meta-location {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f3f5f8;
}

.chips {
  display: flex;
  gap: 12rpx;
}

.chip {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.chip-green {
  background: linear-gradient(135deg, rgba(31, 122, 90, 0.12), rgba(104, 182, 132, 0.18));
  color: #1f7a5a;
}

.chip-warm {
  background: linear-gradient(135deg, rgba(163, 95, 24, 0.12), rgba(242, 193, 78, 0.22));
  color: #a35f18;
}

.chip-cool {
  background: linear-gradient(135deg, rgba(49, 95, 157, 0.12), rgba(126, 182, 217, 0.2));
  color: #315f9d;
}

.seats {
  display: flex;
  align-items: baseline;
  color: #8b939e;
  font-size: 24rpx;
}

.seats-num {
  color: #1f7a5a;
  font-size: 28rpx;
  font-weight: 700;
}

.seats-label {
  margin-left: 4rpx;
  font-size: 22rpx;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.tag-minimal {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.tag-green {
  background: rgba(31, 122, 90, 0.08);
  color: #1f7a5a;
  border: 1rpx solid rgba(31, 122, 90, 0.18);
}

.tag-warm {
  background: rgba(242, 193, 78, 0.12);
  color: #a35f18;
  border: 1rpx solid rgba(242, 193, 78, 0.28);
}

.tag-cool {
  background: rgba(49, 95, 157, 0.08);
  color: #315f9d;
  border: 1rpx solid rgba(49, 95, 157, 0.18);
}

/* ── Map Suggestion ── */
.map-suggestion {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 28rpx 32rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #f0f7f4 0%, #ffffff 55%, #f5f8fc 100%);
  border: 1rpx solid rgba(31, 122, 90, 0.12);
  box-shadow: 0 8rpx 24rpx rgba(31, 122, 90, 0.08);
}

.map-suggestion:active {
  opacity: 0.92;
}

.suggestion-title {
  font-size: 28rpx;
  line-height: 1.4;
  font-weight: 600;
  color: #1a1f28;
}

.suggestion-sub {
  margin-top: 6rpx;
  color: #1f7a5a;
  font-size: 24rpx;
}

.suggestion-icon {
  width: 36rpx;
  height: 36rpx;
  filter: brightness(0) invert(1);
}
