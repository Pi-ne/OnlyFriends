.map-page {
  position: relative;
  min-height: 100vh;
  background: #f7f8fb;
  overflow: hidden;
}

.activity-map {
  width: 100%;
  height: 100vh;
}

.map-chip {
  position: fixed;
  top: 42rpx;
  left: 28rpx;
  z-index: 2;
  display: flex;
  align-items: center;
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.96);
  color: #1a1f28;
  font-size: 26rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 28rpx rgba(25, 32, 43, 0.12);
}

.locate-btn {
  position: fixed;
  top: 42rpx;
  right: 28rpx;
  z-index: 2;
}

.map-state {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  top: 126rpx;
  z-index: 3;
  padding: 24rpx;
}

.summary {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: calc(42rpx + env(safe-area-inset-bottom));
  z-index: 2;
  padding: 26rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 18rpx 46rpx rgba(25, 32, 43, 0.14);
}

.summary-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.summary-main {
  flex: 1;
  min-width: 0;
}

.summary-title {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.35;
  color: #1a1f28;
}

.summary-head .tag {
  flex: 0 0 auto;
  margin: 0;
  white-space: nowrap;
}

.line {
  margin-top: 12rpx;
  font-size: 25rpx;
  line-height: 1.45;
}

.summary-actions {
  margin-top: 22rpx;
}
