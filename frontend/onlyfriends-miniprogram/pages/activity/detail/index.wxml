<view class="detail page">
  <view wx:if="{{loading}}" class="state card">正在加载活动...</view>
  <view wx:elif="{{error}}" class="state error card">{{error}}</view>

  <block wx:elif="{{activity}}">
    <view class="detail-cover {{activity.cover}}">
      <view class="cover-glow"></view>
      <view class="cover-inner">
        <view class="cover-top">
          <view class="status-pill">{{activity.statusText}}</view>
          <text class="cover-category">{{activity.category}}</text>
        </view>
        <view class="cover-bottom">
          <view class="detail-title">{{activity.title}}</view>
          <view class="detail-meta">
            <text class="meta-chip">{{activity.fee}}</text>
            <text class="meta-chip">{{activity.joined}}/{{activity.capacity}} 人</text>
          </view>
        </view>
      </view>
    </view>

    <view class="card info-card">
      <view class="info-grid">
        <view class="info-item">
          <view class="info-label">时间</view>
          <view class="info-value">{{activity.time}}</view>
        </view>
        <view class="info-item">
          <view class="info-label">截止</view>
          <view class="info-value">{{activity.deadline}}</view>
        </view>
      </view>
      <view class="info-item info-item-full">
        <view class="info-label">地点</view>
        <view class="info-value">{{activity.location}}</view>
      </view>
      <view wx:if="{{activity.hasCapacityLimit}}" class="capacity-block">
        <view class="capacity-head">
          <text class="info-label">报名进度</text>
          <text class="capacity-num">{{activity.joined}} / {{activity.capacity}}</text>
        </view>
        <view class="capacity-track">
          <view class="capacity-fill" style="width: {{activity.capacityPercent}}%;"></view>
        </view>
      </view>
      <view wx:else class="capacity-block capacity-block-simple">
        <view class="capacity-head">
          <text class="info-label">已报名</text>
          <text class="capacity-num">{{activity.joined}} 人</text>
        </view>
      </view>
    </view>

    <view wx:if="{{activity.hasLocation}}" class="section card map-card">
      <view class="map-head">
        <view class="map-head-text">
          <view class="section-title compact">活动地点</view>
          <view class="muted map-address">{{activity.locationDetail || activity.location}}</view>
        </view>
        <button class="btn ghost small" bindtap="openNavigation">导航</button>
      </view>
      <map
        class="activity-map"
        latitude="{{activity.latitude}}"
        longitude="{{activity.longitude}}"
        markers="{{activity.markers}}"
        scale="15"
        enable-scroll="{{true}}"
        enable-zoom="{{true}}"
      />
    </view>

    <view class="section card content-card">
      <view class="section-title">活动介绍</view>
      <view class="desc">{{activity.desc}}</view>
      <view wx:if="{{activity.tags.length}}" class="tags">
        <text wx:for="{{activity.tags}}" wx:key="*this" class="tag">{{item}}</text>
      </view>
    </view>

    <view class="section card organizer">
      <view class="organizer-left">
        <view class="organizer-avatar">{{activity.organizerInitial}}</view>
        <view class="organizer-info">
          <view class="organizer-name">{{activity.organizer}}</view>
          <view class="muted organizer-role">活动发起人</view>
        </view>
      </view>
      <button class="btn ghost small organizer-btn" loading="{{followLoading}}" disabled="{{activity.isOwner || followLoading}}" bindtap="followOrganizer">
        {{activity.isOwner ? "本人" : (followedOrganizer ? "已关注" : "关注")}}
      </button>
    </view>

    <view class="section card notice-card">
      <view class="section-title">安全须知</view>
      <view class="desc muted">请按活动说明准时到达，注意个人安全和随身物品。</view>
    </view>

    <view class="bottom-bar">
      <button class="btn secondary share">分享</button>
      <button class="btn" disabled="{{activity.isOwner || registered || !activity.canRegister}}" bindtap="registerNow">
        {{activity.isOwner ? "我发起的活动" : (registered ? "已报名" : (activity.canRegister ? "立即报名" : "暂不可报名"))}}
      </button>
    </view>
  </block>
</view>
