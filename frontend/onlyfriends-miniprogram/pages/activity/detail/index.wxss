.detail {
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.state {
  padding: 26rpx;
  color: #77808f;
  font-size: 26rpx;
  line-height: 1.6;
}

.state.error {
  color: #b5473f;
  background: #fff6f4;
  border-color: #f1c2bc;
}

.detail-cover {
  min-height: 340rpx;
  padding: 30rpx;
  border-radius: 24rpx;
  color: #ffffff;
}

.status-pill {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 24rpx;
}

.detail-title {
  margin-top: 96rpx;
  font-size: 46rpx;
  line-height: 1.18;
  font-weight: 800;
}

.detail-sub {
  margin-top: 16rpx;
  opacity: 0.9;
}

.linear-green {
  background: linear-gradient(135deg, #1f7a5a, #68b684);
}

.linear-yellow {
  background: linear-gradient(135deg, #a35f18, #f2c14e);
}

.linear-blue {
  background: linear-gradient(135deg, #315f9d, #7eb6d9);
}

.info-card {
  margin-top: -34rpx;
  padding: 24rpx;
}

.info-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eef1f5;
}

.info-row:last-child {
  border-bottom: 0;
}

.label {
  width: 96rpx;
  color: #77808f;
}

.value {
  flex: 1;
  color: #19202b;
  font-weight: 600;
}

.map-card {
  padding: 24rpx;
}

.map-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.map-address {
  max-width: 430rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 24rpx;
  line-height: 1.4;
}

.map-head .btn {
  flex-shrink: 0;
}

.activity-map {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.desc {
  font-size: 27rpx;
  line-height: 1.75;
}

.tags {
  margin-top: 20rpx;
}

.organizer {
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.organizer .btn {
  flex-shrink: 0;
  min-width: 120rpx;
}
