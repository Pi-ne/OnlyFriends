<view class="page create">
  <view class="page-header">
    <view class="page-subtitle">填写基本信息，发布你的活动</view>
  </view>

  <view class="quick card">
    <view class="quick-head">
      <view class="quick-badge">AI 助手</view>
      <view class="quick-title">快速生成活动草稿</view>
      <view class="quick-sub">先填写活动名称和地点，AI 可补齐简介、类型和人数建议。</view>
    </view>
    <view class="quick-actions">
      <button class="btn small pill" loading="{{planning}}" disabled="{{planning}}" bindtap="generateAiPlan">AI 策划</button>
    </view>
  </view>

  <view class="section form card">
    <view class="field">
      <text class="field-label">活动名称</text>
      <input class="input" data-key="title" value="{{form.title}}" placeholder="请输入活动名称" bindinput="updateField" />
    </view>
    <view class="field">
      <text class="field-label">活动类型</text>
      <picker mode="selector" range="{{categories}}" value="{{ui.pickerCategoryIndex}}" bindchange="updateCategory">
        <view class="picker-value {{ui.categoryPlaceholder ? 'placeholder' : ''}}">{{ui.categoryText}}</view>
      </picker>
    </view>
    <view class="field">
      <text class="field-label">开始时间</text>
      <view class="datetime-row">
        <picker class="datetime-picker" mode="date" value="{{form.startDate}}" bindchange="updateStartDate">
          <view class="picker-value {{ui.startDatePlaceholder ? 'placeholder' : ''}}">{{ui.startDateText}}</view>
        </picker>
        <picker class="datetime-picker" mode="time" value="{{form.startClock}}" bindchange="updateStartClock">
          <view class="picker-value {{ui.startClockPlaceholder ? 'placeholder' : ''}}">{{ui.startClockText}}</view>
        </picker>
      </view>
    </view>
    <view class="field">
      <text class="field-label">结束时间</text>
      <view class="datetime-row">
        <picker class="datetime-picker" mode="date" value="{{form.endDate}}" bindchange="updateEndDate">
          <view class="picker-value {{ui.endDatePlaceholder ? 'placeholder' : ''}}">{{ui.endDateText}}</view>
        </picker>
        <picker class="datetime-picker" mode="time" value="{{form.endClock}}" bindchange="updateEndClock">
          <view class="picker-value {{ui.endClockPlaceholder ? 'placeholder' : ''}}">{{ui.endClockText}}</view>
        </picker>
      </view>
    </view>
    <view class="field">
      <text class="field-label">报名截止时间</text>
      <view class="datetime-row">
        <picker class="datetime-picker" mode="date" value="{{form.regDate}}" bindchange="updateRegDate">
          <view class="picker-value {{ui.regDatePlaceholder ? 'placeholder' : ''}}">{{ui.regDateText}}</view>
        </picker>
        <picker class="datetime-picker" mode="time" value="{{form.regClock}}" bindchange="updateRegClock">
          <view class="picker-value {{ui.regClockPlaceholder ? 'placeholder' : ''}}">{{ui.regClockText}}</view>
        </picker>
      </view>
      <view class="field-help">须早于开始时间</view>
    </view>
    <view class="field">
      <text class="field-label">地点</text>
      <view class="location-picker {{ui.locationSelected ? 'selected' : ''}}" bindtap="chooseActivityLocation">
        <view class="location-text">
          <view class="location-name">{{ui.locationName}}</view>
          <view class="location-detail">{{ui.locationDetail}}</view>
        </view>
        <view class="location-cta">{{ui.locationCta}}</view>
      </view>
      <input
        wx:if="{{ui.locationSelected}}"
        class="input location-name-input"
        data-key="location"
        value="{{form.location}}"
        placeholder="请输入地点显示名称，如北京航空航天大学"
        bindinput="updateField"
      />
      <view wx:if="{{ui.locationSelected}}" class="location-help">
        地点名称只用于展示，不会改变红点位置；红点不对请点「重选」。
      </view>
      <view wx:if="{{ui.locationSelected}}" class="location-preview">
        <view class="location-preview-head">
          <text>地图红点预览</text>
          <text class="location-preview-tip">位置不对请重选</text>
        </view>
        <map
          class="location-preview-map"
          latitude="{{form.locationLat}}"
          longitude="{{form.locationLng}}"
          markers="{{locationMarkers}}"
          scale="16"
          enable-scroll="{{false}}"
          enable-zoom="{{false}}"
        />
      </view>
    </view>
    <view class="field">
      <text class="field-label">人数上限</text>
      <input class="input" type="number" data-key="capacity" value="{{form.capacity}}" placeholder="请输入人数上限" bindinput="updateField" />
    </view>
    <view class="field field-last">
      <text class="field-label">活动简介</text>
      <textarea class="textarea" data-key="desc" value="{{form.desc}}" placeholder="说明活动流程、适合人群和注意事项" bindinput="updateField" />
    </view>
  </view>

  <view class="btn-group split actions">
    <button class="btn secondary" loading="{{saving}}" disabled="{{saving}}" bindtap="saveDraft">保存草稿</button>
    <button class="btn" loading="{{saving}}" disabled="{{saving}}" bindtap="submitReview">提交审核</button>
  </view>
</view>
