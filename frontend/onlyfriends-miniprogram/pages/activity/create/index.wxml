<view class="page create">
  <view class="quick card">
    <view class="quick-head">
      <view>
        <view class="quick-title">快速生成活动草稿</view>
        <view class="quick-sub">输入主题或套用模板，AI 可补齐简介、标签和参与建议。</view>
      </view>
    </view>
    <view class="quick-actions">
      <button class="btn small pill" loading="{{planning}}" disabled="{{planning}}" bindtap="generateAiPlan">AI 策划</button>
    </view>
  </view>

  <view class="section">
    <view class="section-title">常用模板</view>
    <view wx:if="{{templateLoading}}" class="template-state card">正在加载模板...</view>
    <view wx:elif="{{templateError}}" class="template-state error card">{{templateError}}</view>
    <view wx:elif="{{templates.length === 0}}" class="template-state card">暂无可用模板。</view>
    <scroll-view scroll-x class="template-scroll">
      <view class="template-row">
        <view wx:for="{{templates}}" wx:key="id" data-index="{{index}}" bindtap="useTemplate" class="template card">
          <view class="template-title">{{item.title}}</view>
          <view class="muted template-desc">{{item.desc}}</view>
          <view class="template-chip">{{item.type}}</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="section form card">
    <view class="field">
      <text class="field-label">活动名称</text>
      <input class="input" data-key="title" value="{{form.title}}" placeholder="请输入活动名称" bindinput="updateField" />
    </view>
    <view class="field">
      <text class="field-label">活动类型</text>
      <input class="input" data-key="category" value="{{form.category}}" placeholder="请输入活动类型" bindinput="updateField" />
    </view>
    <view class="field">
      <text class="field-label">时间</text>
      <view class="datetime-row">
        <picker class="datetime-picker" mode="date" value="{{form.date}}" bindchange="updateDate">
          <view class="picker-value {{form.date ? '' : 'placeholder'}}">{{form.date || "选择日期"}}</view>
        </picker>
        <picker class="datetime-picker" mode="time" value="{{form.clock}}" bindchange="updateClock">
          <view class="picker-value {{form.clock ? '' : 'placeholder'}}">{{form.clock || "选择时间"}}</view>
        </picker>
      </view>
      <view class="time-preview">{{form.time ? "提交格式：" + form.time : "选择后自动生成 YYYY-MM-DD HH:mm"}}</view>
    </view>
    <view class="field">
      <text class="field-label">地点</text>
      <view class="location-picker {{form.locationLat !== null ? 'selected' : ''}}" bindtap="chooseActivityLocation">
        <view class="location-text">
          <view class="location-name">{{form.location || (form.locationLat !== null ? "已选择地图位置" : "从地图选择活动地点")}}</view>
          <view class="location-detail">{{form.locationDetail || (form.locationLat !== null ? "请在下方填写具体地点名称" : "选择后会保存真实地图位置")}}</view>
        </view>
        <view class="location-cta">{{form.locationLat !== null ? "重选" : "选择"}}</view>
      </view>
      <input
        wx:if="{{form.locationLat !== null}}"
        class="input location-name-input"
        data-key="location"
        value="{{form.location}}"
        placeholder="请输入地点显示名称，如北京航空航天大学"
        bindinput="updateField"
      />
      <view wx:if="{{form.locationLat !== null}}" class="location-help">
        地点名称只用于展示，不会改变红点位置；红点不对请点“重选”。
      </view>
      <view wx:if="{{form.locationLat !== null}}" class="location-preview">
        <view class="location-preview-head">
          <text>地图红点预览</text>
          <text class="location-preview-tip">位置不对请重选</text>
        </view>
        <map
          class="location-preview-map"
          latitude="{{form.locationLat}}"
          longitude="{{form.locationLng}}"
          markers="{{locationMarkers}}"
          scale="16"
          enable-scroll="{{false}}"
          enable-zoom="{{false}}"
        />
      </view>
    </view>
    <view class="field">
      <text class="field-label">人数上限</text>
      <input class="input" type="number" data-key="capacity" value="{{form.capacity}}" placeholder="请输入人数上限" bindinput="updateField" />
    </view>
    <view class="field">
      <text class="field-label">活动简介</text>
      <textarea class="textarea" data-key="desc" value="{{form.desc}}" placeholder="说明活动流程、适合人群和注意事项" bindinput="updateField" />
    </view>
  </view>

  <view class="btn-group split actions">
    <button class="btn secondary" loading="{{saving}}" disabled="{{saving}}" bindtap="saveDraft">保存草稿</button>
    <button class="btn" loading="{{saving}}" disabled="{{saving}}" bindtap="submitReview">提交审核</button>
  </view>
</view>
