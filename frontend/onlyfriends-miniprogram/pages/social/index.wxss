.page-header.between {
  align-items: flex-start;
  gap: 16rpx;
}

.page-header .btn {
  flex-shrink: 0;
}

.state {
  margin-top: 28rpx;
}

.team {
  margin-top: 20rpx;
  padding: 24rpx;
}

.team-head,
.team-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.team-main {
  flex: 1;
  min-width: 0;
}

.team-name {
  min-height: 44rpx;
  font-size: 31rpx;
  line-height: 1.35;
  font-weight: 700;
}

.topic {
  margin: 12rpx 0 18rpx;
  line-height: 1.5;
}

.team-tags {
  min-height: 56rpx;
  flex: 1;
  min-width: 0;
}

.member-count {
  flex: 0 0 96rpx;
  color: #8b939e;
  font-size: 26rpx;
  text-align: right;
  white-space: nowrap;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx;
  background: rgba(0, 0, 0, 0.45);
}

.modal {
  width: 100%;
  max-height: 86vh;
  padding: 30rpx;
  overflow-y: auto;
}

.modal-title {
  margin-bottom: 24rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
}

.compact-textarea {
  min-height: 128rpx;
}

.picker-box {
  width: 100%;
  min-height: 80rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e4e8ee;
  border-radius: 16rpx;
  background: #ffffff;
  color: #1a1f28;
  line-height: 80rpx;
}

.modal-actions {
  margin-top: 12rpx;
}
