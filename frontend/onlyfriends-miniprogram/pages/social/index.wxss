.social-page {
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* ── Create CTA Banner ── */
.create-cta {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 32rpx;
  padding: 32rpx 28rpx 32rpx 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #164734 0%, #1f7a5a 52%, #3d9e78 100%);
  overflow: hidden;
  box-shadow: 0 16rpx 40rpx rgba(22, 71, 52, 0.22);
}

.create-cta-hover {
  opacity: 0.92;
  transform: scale(0.995);
}

.create-cta-glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.create-cta-glow-a {
  top: -50rpx;
  right: 80rpx;
  width: 180rpx;
  height: 180rpx;
  background: radial-gradient(circle, rgba(242, 193, 78, 0.4) 0%, transparent 70%);
}

.create-cta-glow-b {
  bottom: -70rpx;
  left: -20rpx;
  width: 160rpx;
  height: 160rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.16) 0%, transparent 70%);
}

.create-cta-body {
  position: relative;
  z-index: 1;
  flex: 1;
  min-width: 0;
}

.create-cta-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.78);
  font-weight: 600;
  letter-spacing: 2rpx;
}

.create-cta-title {
  margin-top: 10rpx;
  font-size: 36rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: -0.5rpx;
}

.create-cta-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.72);
}

.create-cta-action {
  position: relative;
  z-index: 1;
  flex: 0 0 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(8rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}

.create-cta-plus {
  font-size: 44rpx;
  font-weight: 300;
  color: #ffffff;
  line-height: 1;
}

/* ── States ── */
.state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: 0;
  padding: 56rpx 40rpx;
  text-align: center;
}

.state-dot {
  width: 12rpx;
  height: 12rpx;
  margin-bottom: 20rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1f7a5a, #68b684);
  animation: pulse 1.4s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.3; transform: scale(0.85); }
  50% { opacity: 1; transform: scale(1); }
}

.empty-state .empty-icon {
  margin-bottom: 16rpx;
  font-size: 48rpx;
  color: #c8ddd4;
  line-height: 1;
}

.empty-state .state-title {
  color: #626d7c;
  font-size: 30rpx;
  font-weight: 600;
}

.empty-state .state-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #a8b0bc;
}

/* ── Team List ── */
.list-section {
  margin-top: 4rpx;
}

.list-section .section-title {
  margin-bottom: 20rpx;
  padding-left: 4rpx;
}

.team {
  margin-top: 0;
  margin-bottom: 20rpx;
  padding: 28rpx;
  transition: opacity 0.15s ease;
}

.team:active {
  opacity: 0.92;
}

.team-head,
.team-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.team-main {
  flex: 1;
  min-width: 0;
}

.team-name {
  min-height: 44rpx;
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #1a1f28;
  letter-spacing: -0.3rpx;
}

.topic {
  margin: 14rpx 0 20rpx;
  line-height: 1.55;
  font-size: 26rpx;
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.team-foot {
  padding-top: 18rpx;
  border-top: 1rpx solid #f3f5f8;
}

.team-tags {
  min-height: 44rpx;
  flex: 1;
  min-width: 0;
}

.member-count {
  flex: 0 0 auto;
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  white-space: nowrap;
}

.member-num {
  color: #1f7a5a;
  font-size: 30rpx;
  font-weight: 700;
}

.member-label {
  color: #8b939e;
  font-size: 22rpx;
}

/* ── Modal ── */
.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 0;
  background: rgba(0, 0, 0, 0.45);
}

.modal {
  width: 100%;
  max-height: 88vh;
  padding: 36rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  border-radius: 32rpx 32rpx 0 0;
  overflow-y: auto;
  animation: slideUp 0.28s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-header {
  margin-bottom: 28rpx;
  text-align: center;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1f28;
}

.modal-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8b939e;
}

.compact-textarea {
  min-height: 128rpx;
}

.picker-box {
  width: 100%;
  min-height: 80rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e4e8ee;
  border-radius: 16rpx;
  background: #ffffff;
  color: #1a1f28;
  line-height: 80rpx;
}

.modal-actions {
  margin-top: 12rpx;
}
