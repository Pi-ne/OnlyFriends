page {
  min-height: 100%;
  background: #f5f7fb;
  color: #1f2937;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

view,
text,
input,
textarea,
button,
picker,
label {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border-radius: 8rpx;
  line-height: 1.2;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 40rpx;
}

.page.with-fixed-bar {
  padding-bottom: 148rpx;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #e5eaf0;
  border-radius: 8rpx;
  padding: 24rpx;
}

.section {
  margin-top: 24rpx;
}

.muted {
  color: #667085;
}

.title {
  color: #111827;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.25;
}

.subtitle {
  color: #667085;
  font-size: 26rpx;
  line-height: 1.55;
}

.row {
  display: flex;
  align-items: center;
}

.between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  color: #344054;
  font-weight: 600;
}

.input,
.textarea,
.picker-box {
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  border: 1rpx solid #d8dee8;
  border-radius: 8rpx;
  background: #ffffff;
  color: #111827;
  font-size: 28rpx;
}

.textarea {
  min-height: 180rpx;
  padding-top: 20rpx;
  line-height: 1.55;
}

.picker-box {
  display: flex;
  align-items: center;
  color: #111827;
}

.btn {
  min-height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 28rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.btn.primary {
  background: #1463d8;
  color: #ffffff;
}

.btn.secondary {
  border: 1rpx solid #cbd5e1;
  background: #ffffff;
  color: #1f2937;
}

.btn.ghost {
  background: #edf4ff;
  color: #1463d8;
}

.btn.danger {
  background: #dc2626;
  color: #ffffff;
}

.btn[disabled] {
  opacity: 0.55;
}

.pill {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #1463d8;
  font-size: 22rpx;
  font-weight: 700;
}

.fixed-action {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 10;
  display: flex;
  gap: 16rpx;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #e5eaf0;
  background: #ffffff;
}

.fixed-action .btn {
  flex: 1;
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.tabs {
  display: flex;
  gap: 8rpx;
  padding: 8rpx;
  border: 1rpx solid #dfe6ef;
  border-radius: 8rpx;
  background: #eaf0f7;
}

.tab {
  flex: 1;
  min-height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6rpx;
  color: #667085;
  font-weight: 700;
}

.tab.active {
  background: #ffffff;
  color: #111827;
}
