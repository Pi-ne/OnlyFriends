<view class="page">
  <view class="tabs">
    <view class="tab {{mode === 'registered' ? 'active' : ''}}" data-mode="registered" bindtap="switchMode">报名记录</view>
    <view class="tab {{mode === 'created' ? 'active' : ''}}" data-mode="created" bindtap="switchMode">我发布的</view>
  </view>
  <loading-state wx:if="{{loading}}" text="加载活动"></loading-state>
  <empty-state wx:elif="{{!activities.length}}" title="暂无活动" mark="活"></empty-state>
  <view wx:else class="list">
    <activity-card wx:for="{{activities}}" wx:key="activityId" activity="{{item}}" bind:tap-detail="goDetail"></activity-card>
  </view>
</view>
