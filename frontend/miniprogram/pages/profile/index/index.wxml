<view class="page">
  <view wx:if="{{!loggedIn}}" class="panel login-panel">
    <view class="title">登录后使用完整功能</view>
    <view class="subtitle">查看报名记录、通知、小队和商家申请状态。</view>
    <button class="btn primary" bindtap="goLogin">去登录</button>
  </view>

  <block wx:else>
    <view class="panel profile">
      <user-avatar src="{{profile.avatarUrl}}" name="{{profile.nickname}}" size="{{104}}"></user-avatar>
      <view class="profile-main">
        <view class="title">{{profile.nickname || 'OnlyFriends 用户'}}</view>
        <view class="subtitle">{{profile.bio || '还没有填写简介'}}</view>
        <view class="pill">信誉分 {{profile.creditScore || 100}}</view>
      </view>
    </view>

    <view class="stats">
      <view class="panel stat"><text>{{registeredCount}}</text><text>已报名</text></view>
      <view class="panel stat"><text>{{createdCount}}</text><text>已发布</text></view>
      <view class="panel stat"><text>{{teamCount}}</text><text>小队</text></view>
    </view>

    <view class="menu">
      <button bindtap="goEdit">编辑资料</button>
      <button bindtap="goActivities">我的活动</button>
      <button bindtap="goNotifications">我的通知</button>
      <button bindtap="goTeams">我的小队</button>
      <button bindtap="goMerchant">商家申请</button>
      <button bindtap="logout">退出登录</button>
    </view>
  </block>
</view>
