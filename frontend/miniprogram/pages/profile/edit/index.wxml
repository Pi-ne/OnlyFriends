<view class="page">
  <view class="panel stack">
    <label class="field">昵称<input class="input" value="{{form.nickname}}" bindinput="onNicknameInput" /></label>
    <label class="field">简介<textarea class="textarea" value="{{form.bio}}" bindinput="onBioInput"></textarea></label>
    <button class="btn primary" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submit">保存资料</button>
  </view>
</view>
