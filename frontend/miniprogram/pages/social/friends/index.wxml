<view class="page">
  <view class="tabs">
    <view class="tab {{tab === 'friends' ? 'active' : ''}}" data-tab="friends" bindtap="switchTab">好友</view>
    <view class="tab {{tab === 'following' ? 'active' : ''}}" data-tab="following" bindtap="switchTab">关注</view>
    <view class="tab {{tab === 'followers' ? 'active' : ''}}" data-tab="followers" bindtap="switchTab">粉丝</view>
    <view class="tab {{tab === 'applies' ? 'active' : ''}}" data-tab="applies" bindtap="switchTab">申请</view>
  </view>
  <view class="list">
    <view wx:for="{{list}}" wx:key="userId" class="panel user-row">
      <user-avatar src="{{item.avatarUrl}}" name="{{item.nickname || item.applicantNickname}}" size="{{72}}"></user-avatar>
      <view class="main">
        <view class="name">{{item.nickname || item.applicantNickname || item.targetNickname}}</view>
        <view class="subtitle">{{item.remark || item.groupName || item.message || '趣聚用户'}}</view>
      </view>
      <button wx:if="{{tab === 'applies'}}" class="mini primary" data-id="{{item.applyId}}" data-action="1" bindtap="review">同意</button>
      <button wx:if="{{tab === 'applies'}}" class="mini" data-id="{{item.applyId}}" data-action="2" bindtap="review">拒绝</button>
    </view>
  </view>
  <empty-state wx:if="{{!list.length}}" title="暂无内容" mark="友"></empty-state>
</view>
