.list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
}

.user-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.main {
  flex: 1;
  min-width: 0;
}

.name {
  color: #111827;
  font-weight: 800;
}

.mini {
  min-height: 58rpx;
  padding: 0 18rpx;
  border: 1rpx solid #cbd5e1;
  border-radius: 8rpx;
  background: #ffffff;
  color: #1f2937;
  font-size: 24rpx;
}

.mini.primary {
  border-color: #1463d8;
  background: #1463d8;
  color: #ffffff;
}
