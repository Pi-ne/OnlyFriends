.row-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.main {
  flex: 1;
}

.name {
  color: #111827;
  font-weight: 800;
}

.mini {
  min-height: 58rpx;
  padding: 0 16rpx;
  border: 1rpx solid #cbd5e1;
  border-radius: 8rpx;
  background: #ffffff;
  color: #1f2937;
  font-size: 24rpx;
}

.mini.primary {
  background: #1463d8;
  color: #ffffff;
}
