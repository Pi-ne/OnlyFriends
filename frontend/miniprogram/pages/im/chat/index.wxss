.chat-page {
  min-height: 100vh;
  padding-bottom: 128rpx;
}

.messages {
  height: calc(100vh - 160rpx);
}

.msg {
  display: flex;
  margin-bottom: 16rpx;
}

.msg.mine {
  justify-content: flex-end;
}

.bubble {
  max-width: 76%;
  padding: 18rpx 22rpx;
  border-radius: 8rpx;
  background: #ffffff;
  color: #111827;
  line-height: 1.55;
}

.mine .bubble {
  background: #1463d8;
  color: #ffffff;
}

.composer {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  gap: 12rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #e2e8f0;
  background: #ffffff;
}

.composer .input {
  flex: 1;
}

.send {
  width: 116rpx;
  min-height: 88rpx;
  border-radius: 8rpx;
  background: #1463d8;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
}
