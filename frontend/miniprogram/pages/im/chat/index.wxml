<view class="page chat-page">
  <scroll-view class="messages" scroll-y scroll-into-view="{{scrollIntoView}}">
    <view wx:for="{{messages}}" wx:key="msgId" id="msg-{{item.msgId}}" class="msg {{item.mine ? 'mine' : ''}}">
      <view class="bubble">{{item.recalledAt ? '消息已撤回' : item.content}}</view>
    </view>
  </scroll-view>
  <view class="composer">
    <input class="input" value="{{content}}" placeholder="输入消息" bindinput="onInput" confirm-type="send" bindconfirm="send" />
    <button class="send" loading="{{sending}}" disabled="{{sending}}" bindtap="send">发送</button>
  </view>
</view>
