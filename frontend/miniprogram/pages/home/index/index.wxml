<view class="page">
  <view class="top">
    <view>
      <view class="city">{{city}}</view>
      <view class="title">发现活动</view>
    </view>
    <button class="map-btn" bindtap="goMap">地图</button>
  </view>

  <view class="search-row">
    <input class="search" value="{{keyword}}" placeholder="搜索活动、地点、标签" confirm-type="search" bindinput="onKeywordInput" bindconfirm="refresh" />
    <button class="filter-btn" bindtap="toggleFilter">筛选</button>
  </view>

  <view class="tabs">
    <view wx:for="{{tabs}}" wx:key="key" class="tab {{activeTab === item.key ? 'active' : ''}}" data-key="{{item.key}}" bindtap="switchTab">{{item.name}}</view>
  </view>

  <view wx:if="{{showFilter}}" class="panel filter-panel stack">
    <label class="field">
      标签
      <input class="input" value="{{filters.tags}}" placeholder="如 户外、桌游" bindinput="onTagsInput" />
    </label>
    <view class="grid-2">
      <label class="field">
        最低费用
        <input class="input" type="digit" value="{{filters.minFee}}" placeholder="0" bindinput="onMinFeeInput" />
      </label>
      <label class="field">
        最高费用
        <input class="input" type="digit" value="{{filters.maxFee}}" placeholder="不限" bindinput="onMaxFeeInput" />
      </label>
    </view>
    <button class="btn primary" bindtap="applyFilter">应用筛选</button>
  </view>

  <loading-state wx:if="{{loading && !activities.length}}" text="正在加载活动"></loading-state>
  <empty-state wx:elif="{{state === 'empty'}}" title="暂无活动" description="换个关键词或稍后再来看看。" mark="活"></empty-state>
  <empty-state wx:elif="{{state === 'error'}}" title="加载失败" description="请检查后端网关是否已启动。" buttonText="重试" mark="错" bind:tap-action="refresh"></empty-state>

  <view wx:else class="list">
    <activity-card wx:for="{{activities}}" wx:key="activityId" activity="{{item}}" bind:tap-detail="goDetail"></activity-card>
    <view wx:if="{{loading}}" class="load-more">加载中...</view>
    <view wx:elif="{{!hasMore}}" class="load-more">没有更多了</view>
  </view>
</view>
