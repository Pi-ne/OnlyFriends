.top,
.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.top {
  justify-content: space-between;
}

.city {
  color: #1463d8;
  font-size: 24rpx;
  font-weight: 800;
}

.map-btn,
.filter-btn {
  min-width: 104rpx;
  min-height: 72rpx;
  border: 1rpx solid #cbd5e1;
  border-radius: 8rpx;
  background: #ffffff;
  color: #1f2937;
  font-size: 26rpx;
  font-weight: 700;
}

.search {
  flex: 1;
  min-height: 72rpx;
  padding: 0 22rpx;
  border: 1rpx solid #d8dee8;
  border-radius: 8rpx;
  background: #ffffff;
}

.filter-panel {
  margin: 20rpx 0;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 20rpx;
}

.load-more {
  padding: 24rpx;
  color: #667085;
  text-align: center;
}
