<view class="page auth-page">
  <view class="hero">
    <view class="brand">趣聚</view>
    <view class="title">欢迎回来</view>
    <view class="subtitle">登录后可以报名活动、加入小队和查看消息。</view>
  </view>

  <view class="panel stack">
    <label class="field">
      邮箱
      <input class="input" type="text" value="{{email}}" placeholder="请输入邮箱" bindinput="onEmailInput" />
    </label>
    <label class="field">
      密码
      <input class="input" password value="{{password}}" placeholder="请输入密码" bindinput="onPasswordInput" />
    </label>
    <button class="btn primary" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submit">登录</button>
    <button class="btn secondary" bindtap="goRegister">去注册</button>
  </view>
</view>
