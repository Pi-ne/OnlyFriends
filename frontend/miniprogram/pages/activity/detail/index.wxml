<view class="page with-fixed-bar">
  <loading-state wx:if="{{state === 'loading'}}" text="正在加载活动"></loading-state>
  <empty-state wx:elif="{{state === 'error'}}" title="活动加载失败" description="请稍后重试。" buttonText="重试" mark="错" bind:tap-action="loadAll"></empty-state>

  <block wx:else>
    <view class="cover">
      <image wx:if="{{activity.coverUrl}}" src="{{activity.coverUrl}}" mode="aspectFill"></image>
      <view wx:else class="cover-fallback">OnlyFriends 活动</view>
    </view>

    <view class="panel detail-head">
      <view class="between">
        <view class="pill">{{activity.statusText || '活动'}}</view>
        <view class="fee">{{feeText}}</view>
      </view>
      <view class="title">{{activity.title}}</view>
      <view class="tags">
        <text wx:for="{{activity.tags}}" wx:key="*this" class="tag">{{item}}</text>
      </view>
      <view class="meta">开始：{{startText}}</view>
      <view class="meta">结束：{{endText}}</view>
      <view class="meta">报名截止：{{deadlineText}}</view>
      <view class="meta">地点：{{activity.locationName}} {{activity.locationDetail}}</view>
      <view class="meta">人数：{{activity.currentCount || 0}}/{{activity.maxParticipants || 0}}</view>
    </view>

    <view class="panel section">
      <view class="creator">
        <user-avatar src="{{activity.creatorAvatarUrl}}" name="{{activity.creatorNickname}}" size="{{72}}"></user-avatar>
        <view>
          <view class="creator-name">{{activity.creatorNickname || '发起人'}}</view>
          <view class="subtitle">活动发起人</view>
        </view>
      </view>
    </view>

    <view class="panel section">
      <view class="section-title">活动说明</view>
      <view class="desc">{{activity.description || '暂无说明'}}</view>
    </view>

    <view class="panel section">
      <view class="section-title">评价</view>
      <view wx:if="{{comments.length}}" class="comments">
        <view wx:for="{{comments}}" wx:key="commentId" class="comment">
          <view class="between">
            <text>{{item.nickname || item.userNickname || '用户'}}</text>
            <text>{{item.rating || 5}} 分</text>
          </view>
          <view class="subtitle">{{item.content}}</view>
        </view>
      </view>
      <view wx:else class="subtitle">暂无评价</view>
    </view>
  </block>

  <view wx:if="{{state === 'success'}}" class="fixed-action">
    <button wx:if="{{primaryAction}}" class="btn {{primaryAction.type}}" loading="{{submitting}}" disabled="{{submitting}}" bindtap="handlePrimary">{{primaryAction.text}}</button>
    <button class="btn secondary" bindtap="goHome">返回发现</button>
  </view>
</view>
