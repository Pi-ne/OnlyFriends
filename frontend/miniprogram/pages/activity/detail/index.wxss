.cover {
  overflow: hidden;
  height: 360rpx;
  margin: -24rpx -24rpx 24rpx;
  background: #dce8f8;
}

.cover image,
.cover-fallback {
  width: 100%;
  height: 100%;
}

.cover-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1463d8, #12a474);
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 800;
}

.detail-head {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.fee {
  color: #12a474;
  font-weight: 800;
}

.tags,
.comments {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tags {
  flex-direction: row;
  flex-wrap: wrap;
}

.tag {
  min-height: 42rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #475467;
  font-size: 22rpx;
  line-height: 42rpx;
}

.meta {
  color: #475467;
  font-size: 26rpx;
  line-height: 1.5;
}

.creator {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.creator-name,
.section-title {
  color: #111827;
  font-weight: 800;
}

.desc {
  color: #344054;
  line-height: 1.7;
}

.comment {
  padding: 18rpx;
  border-radius: 8rpx;
  background: #f8fafc;
}
