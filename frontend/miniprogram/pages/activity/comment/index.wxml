<view class="page">
  <view class="panel stack">
    <label class="field">评分<input class="input" type="number" value="{{rating}}" bindinput="onRatingInput" /></label>
    <label class="field">评价<textarea class="textarea" value="{{content}}" bindinput="onContentInput"></textarea></label>
    <button class="btn primary" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submit">发布评价</button>
  </view>
</view>
