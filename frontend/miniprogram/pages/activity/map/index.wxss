.map-page,
.map {
  width: 100%;
  height: 100vh;
}

.selected {
  position: fixed;
  right: 24rpx;
  bottom: 40rpx;
  left: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 22rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(17, 24, 39, 0.16);
}

.name {
  color: #111827;
  font-weight: 800;
}
