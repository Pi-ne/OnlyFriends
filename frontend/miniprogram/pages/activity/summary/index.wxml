<view class="page">
  <view class="panel stack">
    <label class="field">标题<input class="input" value="{{title}}" bindinput="onTitleInput" /></label>
    <label class="field">内容<textarea class="textarea" value="{{content}}" bindinput="onContentInput"></textarea></label>
    <button class="btn primary" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submit">发布总结</button>
  </view>
</view>
