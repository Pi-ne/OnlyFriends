<view class="page">
  <view class="search-row">
    <input class="search" value="{{keyword}}" placeholder="搜索小队" bindinput="onKeywordInput" bindconfirm="loadRecommended" />
    <button class="create" bindtap="goCreate">创建</button>
  </view>

  <view class="section">
    <view class="between head">
      <view class="title small">我的小队</view>
      <button class="link" bindtap="loadJoined">刷新</button>
    </view>
    <view wx:if="{{joinedTeams.length}}" class="list">
      <team-card wx:for="{{joinedTeams}}" wx:key="teamId" team="{{item}}" bind:tap-detail="goDetail"></team-card>
    </view>
    <empty-state wx:else title="还没有加入小队" mark="队"></empty-state>
  </view>

  <view class="section">
    <view class="title small">推荐小队</view>
    <loading-state wx:if="{{loading}}" text="加载小队"></loading-state>
    <view wx:elif="{{teams.length}}" class="list">
      <team-card wx:for="{{teams}}" wx:key="teamId" team="{{item}}" bind:tap-detail="goDetail"></team-card>
    </view>
    <empty-state wx:else title="暂无推荐小队" mark="队"></empty-state>
  </view>
</view>
