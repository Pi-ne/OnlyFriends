<view class="page with-fixed-bar">
  <view class="panel stack">
    <view class="between">
      <view class="title">{{team.name || '小队'}}</view>
      <view class="pill">{{team.joined ? '已加入' : '可加入'}}</view>
    </view>
    <view class="subtitle">{{team.description || '暂无介绍'}}</view>
    <view class="tags">
      <text wx:for="{{team.tags}}" wx:key="*this" class="tag">{{item}}</text>
    </view>
    <view class="subtitle">{{team.memberCount || 0}}/{{team.maxMembers || 0}} 成员 · 积分 {{team.score || 0}}</view>
  </view>

  <view class="tabs section">
    <view wx:for="{{tabs}}" wx:key="key" class="tab {{activeTab === item.key ? 'active' : ''}}" data-key="{{item.key}}" bindtap="switchTab">{{item.name}}</view>
  </view>

  <view class="panel section">
    <view wx:if="{{activeTab === 'feed'}}">
      <view wx:for="{{announcements}}" wx:key="announcementId" class="item">
        <view class="name">{{item.title}}</view>
        <view class="subtitle">{{item.content}}</view>
      </view>
      <empty-state wx:if="{{!announcements.length}}" title="暂无动态" mark="动"></empty-state>
    </view>

    <view wx:elif="{{activeTab === 'members'}}">
      <view wx:for="{{members}}" wx:key="userId" class="member">
        <user-avatar src="{{item.avatarUrl}}" name="{{item.nickname}}" size="{{64}}"></user-avatar>
        <view class="name">{{item.nickname}}</view>
        <view class="pill">{{item.roleText || item.role || '成员'}}</view>
      </view>
      <empty-state wx:if="{{!members.length}}" title="暂无成员" mark="人"></empty-state>
    </view>

    <view wx:elif="{{activeTab === 'album'}}">
      <view class="subtitle">相册 {{album.length}} 张</view>
    </view>
    <view wx:elif="{{activeTab === 'files'}}">
      <view wx:for="{{files}}" wx:key="fileId" class="item">{{item.fileName}}</view>
      <empty-state wx:if="{{!files.length}}" title="暂无文件" mark="文"></empty-state>
    </view>
    <view wx:elif="{{activeTab === 'votes'}}">
      <view wx:for="{{votes}}" wx:key="voteId" class="item">{{item.title}}</view>
      <empty-state wx:if="{{!votes.length}}" title="暂无投票" mark="票"></empty-state>
    </view>
    <view wx:else>
      <view wx:for="{{scores}}" wx:key="userId" class="item">{{item.nickname}} · {{item.score}} 分</view>
      <empty-state wx:if="{{!scores.length}}" title="暂无积分" mark="分"></empty-state>
    </view>
  </view>

  <view class="fixed-action">
    <button class="btn {{team.joined ? 'danger' : 'primary'}}" loading="{{submitting}}" disabled="{{submitting}}" bindtap="toggleJoin">{{team.joined ? '退出小队' : '加入小队'}}</button>
    <button class="btn secondary" bindtap="goChat">小队群聊</button>
  </view>
</view>
