.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  min-height: 40rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #475467;
  font-size: 22rpx;
  line-height: 40rpx;
}

.item,
.member {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef2f6;
}

.member {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.name {
  flex: 1;
  color: #111827;
  font-weight: 800;
}
