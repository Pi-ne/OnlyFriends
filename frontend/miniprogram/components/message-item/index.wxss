.item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 8rpx;
  background: #ffffff;
}

.main {
  flex: 1;
  min-width: 0;
}

.top {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.title {
  overflow: hidden;
  color: #111827;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.time,
.preview {
  color: #667085;
  font-size: 24rpx;
}

.preview {
  overflow: hidden;
  margin-top: 6rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.unread {
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #dc2626;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 36rpx;
  text-align: center;
}
