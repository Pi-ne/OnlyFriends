.card {
  overflow: hidden;
  border: 1rpx solid #e2e8f0;
  border-radius: 8rpx;
  background: #ffffff;
}

.cover {
  position: relative;
  height: 220rpx;
  overflow: hidden;
  background: #dce8f8;
}

.cover image,
.cover-fallback {
  width: 100%;
  height: 100%;
}

.cover-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1463d8, #12a474);
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 800;
}

.status {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(17, 24, 39, 0.72);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 20rpx;
}

.title {
  color: #111827;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.35;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  min-height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #1463d8;
  font-size: 22rpx;
  line-height: 40rpx;
}

.meta,
.foot {
  color: #667085;
  font-size: 24rpx;
  line-height: 1.45;
}

.foot {
  display: flex;
  justify-content: space-between;
}

.detail {
  min-height: 72rpx;
  margin-top: 4rpx;
  border-radius: 8rpx;
  background: #1463d8;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
}
