.card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 22rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 8rpx;
  background: #ffffff;
}

.top {
  display: flex;
  gap: 16rpx;
}

.avatar {
  flex: none;
  width: 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background: #1463d8;
  color: #ffffff;
  font-weight: 800;
}

.main {
  flex: 1;
  min-width: 0;
}

.name {
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
}

.desc {
  margin-top: 6rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.45;
}

.state {
  flex: none;
  height: 42rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #1463d8;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  min-height: 38rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #475467;
  font-size: 22rpx;
  line-height: 38rpx;
}

.foot {
  display: flex;
  justify-content: space-between;
  color: #667085;
  font-size: 24rpx;
}
